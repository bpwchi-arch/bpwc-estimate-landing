# ─────────────────────────────────────────────────────────────
# Blue Pacific Window Cleaning — Server Environment Variables
# Copy this to .env and fill in your values
# In production (Idealane/Render/Railway): set in the dashboard
# ─────────────────────────────────────────────────────────────

# ── Cloudflare R2 (Photo Storage) ────────────────────────────
# Cloudflare Dashboard > R2 > Manage API Tokens
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET_NAME=blue-pacific-photos
# Optional: public bucket URL or custom domain
# R2_PUBLIC_URL=https://photos.bluepacificwindowcleaning.com

# ── Slack Notifications ───────────────────────────────────────
# api.slack.com/apps > Create App > Incoming Webhooks > #new-estimates
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# ── Email ─────────────────────────────────────────────────────

# Option A: Gmail App Password (easiest)
# Enable at: myaccount.google.com/apppasswords
GMAIL_USER=sales@bpwchi.com
GMAIL_PASS=your_gmail_app_password

# Option B: Generic SMTP (SendGrid, Postmark, Mailgun, etc.)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key
# SMTP_FROM=sales@bpwchi.com

# Where internal team notifications go
TEAM_EMAIL=sales@bpwchi.com

# ── ClickSend SMS Fallback ────────────────────────────────────
# Primary SMS = Zapier → Quo (already wired)
# ClickSend fires automatically ONLY if Zapier/Quo fails
# Get credentials: app.clicksend.com > API Credentials
CLICKSEND_USERNAME=your_clicksend_username
CLICKSEND_API_KEY=your_clicksend_api_key
# Optional: sender name shown on texts (max 11 chars, no spaces)
CLICKSEND_FROM=BluePacific

# ── Zapier Webhooks ───────────────────────────────────────────
# Pre-configured — only override if your webhook URLs change
# ZAPIER_SMS_WEBHOOK=https://hooks.zapier.com/hooks/catch/14536948/uer2igu/
# ZAPIER_SUBMIT_WEBHOOK=https://hooks.zapier.com/hooks/catch/14536948/uerttj9/

# ── App URL ───────────────────────────────────────────────────
# The public URL of this deployed app
BASE_URL=https://your-production-url.com
ESTIMATE_URL=https://your-production-url.com
